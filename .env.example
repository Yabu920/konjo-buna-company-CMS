# Runtime mode (production must use MySQL)
NODE_ENV=production
DATA_SOURCE=mysql
DATABASE_URL=mysql://USER:URL_ENCODED_PASSWORD@HOST:3306/DATABASE_NAME

# Canonical public HTTPS URL used in password-reset links
APP_URL=https://www.konjobuna.com

# Passenger normally injects PORT. Keep this only for direct local starts.
PORT=3000

# Password-recovery SMTP. Use provider-issued credentials.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Konjo Coffee <no-reply@example.com>"

# Persistent uploads. An absolute cPanel path is recommended in production.
UPLOAD_DIR=/home/CPANEL_USER/konjo-shared/uploads
PUBLIC_UPLOAD_PATH=/uploads

# Use false locally. In cPanel, use only the provider-confirmed proxy IP/CIDR,
# loopback, or verified hop count. Broad values such as true are rejected.
TRUST_PROXY=false

# Enable only after HTTPS termination and proxy forwarding are confirmed.
HSTS_ENABLED=false

# Single-process bounded in-memory rate limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_ENTRIES=10000
LOGIN_RATE_LIMIT_MAX=10
RECOVERY_IP_RATE_LIMIT_MAX=10
RECOVERY_TARGET_RATE_LIMIT_MAX=5
INQUIRY_RATE_LIMIT_MAX=10
NEWSLETTER_RATE_LIMIT_MAX=20

# Explicit local JSON development only. Leave bootstrap fields blank unless a
# local administrator is required; no default password is provided.
JSON_DB_FILE=database.local.json
JSON_BOOTSTRAP_USERNAME=
JSON_BOOTSTRAP_PASSWORD=
JSON_BOOTSTRAP_EMAIL=
JSON_BOOTSTRAP_NAME=
