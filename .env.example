# cPanel MySQL connection details
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# Prisma MySQL URL, for example:
# mysql://DB_USER:DB_PASSWORD@DB_HOST:3306/DB_NAME
DATABASE_URL=mysql://DB_USER:DB_PASSWORD@DB_HOST:3306/DB_NAME

# Keep JSON as the safe default. Switch to mysql only after migration and import.
DATA_SOURCE=mysql

# Public URL used in Super Admin password-reset links.
APP_URL=http://localhost:3000

# SMTP password-recovery delivery
