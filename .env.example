SMTP_PORT=2525
SMTP_USER=032ed61eeb380c
SMTP_PASSWORD=fa9ecd6598d172
SMTP_FROM="Konjo Coffee <no-reply@konjocoffee.test>"

# Express and upload configuration
PORT=3000
UPLOAD_DIR=uploads
PUBLIC_UPLOAD_PATH=/uploads
